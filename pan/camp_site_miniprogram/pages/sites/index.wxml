<view class="container">
  <view class="filter-bar">
    <view class="filter-item {{filters.hasToilet ? 'active' : ''}}" bindtap="onToggleFilter" data-key="hasToilet">
      <text>有卫生间</text>
    </view>
    <view class="filter-item {{filters.isActive ? 'active' : ''}}" bindtap="onToggleFilter" data-key="isActive">
      <text>活跃营地</text>
    </view>
    <view class="filter-item {{filters.favoriteOnly ? 'active' : ''}}" bindtap="onToggleFilter" data-key="favoriteOnly">
      <text>已收藏</text>
    </view>
  </view>

  <view class="search-row">
    <input
      class="search-input"
      value="{{filters.keyword}}"
      placeholder="搜索营地名称、备注、标签"
      bindinput="onKeywordInput"
      confirm-type="search"
    />
    <view class="reset" bindtap="onReset">重置</view>
  </view>

  <view class="summary">
    <text>共 {{sites.length}} 个营地</text>
  </view>

  <view class="empty" wx:if="{{!sites.length}}">
    暂无满足条件的营地，试试调整筛选项
  </view>

  <view
    class="card site-item"
    wx:for="{{sites}}"
    wx:key="id"
    data-id="{{item.id}}"
    bindtap="onTapItem"
  >
    <view class="row-between">
      <view class="title">{{item.name}}</view>
      <view class="favorite {{item.isFavorite ? 'on' : ''}}" catchtap="onToggleFavorite" data-id="{{item.id}}">
        {{item.isFavorite ? '★' : '☆'}}
      </view>
    </view>
    <view class="subtitle">{{item.address}}</view>

    <view class="tag-row">
      <view class="tag" wx:if="{{item.hasToilet === true}}">卫生间</view>
      <view class="tag warn" wx:if="{{item.hasToilet === false}}">无卫生间</view>
      <view class="tag muted" wx:if="{{item.hasToilet === null}}">卫生间未知</view>

      <view class="tag" wx:if="{{item.isActive === true}}">活跃</view>
      <view class="tag warn" wx:if="{{item.isActive === false}}">已停用</view>
      <view class="tag muted" wx:if="{{item.isActive === null}}">状态未知</view>

      <view class="tag" wx:for="{{item.seasonLabels}}" wx:for-item="season" wx:key="*this">{{season}}</view>
    </view>

    <view class="actions">
      <view class="btn-secondary" catchtap="onLocateOnMap" data-id="{{item.id}}">在地图查看</view>
      <view class="btn-primary" catchtap="onGoDetail" data-id="{{item.id}}">详情</view>
    </view>
  </view>
</view>
